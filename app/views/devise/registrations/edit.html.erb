<div class="top-margin"></div>
<div class="container mb-5 pb-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <h1 class="mb-4">Edit Profile</h1>

      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.error_notification %>

        <div class="form-inputs">
          <h5 class="mt-4 mb-3">Profile Information</h5>

          <%= f.input :first_name, required: true, autofocus: true %>
          <%= f.input :last_name, required: true %>

          <%= f.input :avatar, as: :file,
                      label: "Profile Picture",
                      hint: "Upload a new profile picture (optional)",
                      input_html: { accept: 'image/*' } %>

          <% if resource.persisted? && resource.avatar.attached? && resource.avatar.blob.persisted? %>
            <div class="mb-3">
              <p class="small text-muted">Current avatar:</p>
              <%= image_tag url_for(resource.avatar.variant(resize_to_limit: [200, 200])), class: "rounded-circle", style: "width: 80px; height: 80px; object-fit: cover;" %>
            </div>
          <% end %>

          <hr class="my-4">

          <%= f.input :email, required: true, disabled: true, hint: "Email cannot be changed" %>

          <h5 class="mt-4 mb-3">Change Password</h5>

          <%= f.input :password,
                      label: "New Password",
                      hint: "Leave blank if you don't want to change it",
                      required: false,
                      input_html: { autocomplete: "new-password" } %>
          <%= f.input :password_confirmation,
                      label: "Confirm New Password",
                      required: false,
                      input_html: { autocomplete: "new-password" } %>

          <hr class="my-4">

          <%= f.input :current_password,
                      label: "Current Password",
                      hint: "We need your current password to confirm your changes",
                      required: true,
                      input_html: { autocomplete: "current-password" } %>
        </div>

        <div class="form-actions">
          <%= f.button :submit, "Update Profile", class: "btn btn-primary w-100" %>
        </div>
      <% end %>

      <div class="mt-3">
        <%= link_to "← Back", :back, class: "btn btn-link" %>
      </div>
    </div>
  </div>
</div>
