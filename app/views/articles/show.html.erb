<%
  summary = truncate(strip_tags(@article.content.to_s).squish, length: 160)
  image_url_for_meta = @article.images.attached? ? url_for(@article.images.first) : nil

  set_meta_tags(
    title: "#{@article.title} | Blog IT B-IT Consulting",
    description: summary,
    canonical: article_url(@article),
    image: image_url_for_meta
  )

  article_structured_data = {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": @article.title,
    "description": summary,
    "mainEntityOfPage": article_url(@article),
    "author": {
      "@type": "Person",
      "name": "Benoît Marfany"
    },
    "publisher": {
      "@type": "Organization",
      "name": "B-IT Consulting",
      "logo": {
        "@type": "ImageObject",
        "url": asset_url("Logo/Vista Logos/logo-transparent-png.png")
      }
    }
  }
  article_structured_data["image"] = image_url_for_meta if image_url_for_meta.present?
  article_structured_data["datePublished"] = @article.date.iso8601 if @article.date.present?
%>

<% content_for :structured_data do %>
  <%= tag.script(type: "application/ld+json") do %>
    <%= article_structured_data.to_json.html_safe %>
  <% end %>
<% end %>

<div class="article-show-page top-margin">
  <nav class="article-breadcrumb">
    <%= link_to "← Retour au blog", articles_path, class: "back-link" %>
  </nav>

  <header class="article-hero">
    <p class="article-kicker">Le numérique en Nouvelle-Aquitaine</p>
    <h1 class="article-title"><%= @article.title %></h1>
    <p class="article-meta">
      <time datetime="<%= @article.date %>"><%= @article.date&.strftime("%d %B %Y") %></time>
    </p>

    <% if @article.images.attached? %>
      <% if @article.images.many? %>
        <div class="article-cover article-carousel" data-controller="article-carousel">
          <div class="article-carousel__viewport" aria-live="polite">
            <% @article.images.each_with_index do |img, idx| %>
              <figure
                class="article-carousel__slide"
                data-article-carousel-target="slide"
                <%= "hidden" unless idx.zero? %>
              >
                <%= image_tag url_for(img), alt: "#{@article.title} – image #{idx + 1}", class: "article-image" %>
              </figure>
            <% end %>
          </div>

          <button
            type="button"
            class="article-carousel__control article-carousel__control--prev"
            aria-label="Image précédente"
            data-action="article-carousel#prev"
          >
            ‹
          </button>

          <button
            type="button"
            class="article-carousel__control article-carousel__control--next"
            aria-label="Image suivante"
            data-action="article-carousel#next"
          >
            ›
          </button>

          <div class="article-carousel__indicators">
            <% @article.images.each_with_index do |_, idx| %>
              <button
                type="button"
                class="article-carousel__indicator <%= 'is-active' if idx.zero? %>"
                aria-label="Voir l'image <%= idx + 1 %>"
                aria-current="<%= idx.zero? %>"
                data-action="article-carousel#go"
                data-article-carousel-target="indicator"
                data-index="<%= idx %>"
              ></button>
            <% end %>
          </div>
        </div>
      <% else %>
        <div class="article-cover">
          <%= image_tag url_for(@article.images.first), alt: @article.title, class: "article-image" %>
        </div>
      <% end %>
    <% elsif @article.video_embed_url.present? %>
      <div class="article-cover video-wrapper">
        <iframe
          src="<%= @article.video_embed_url %>"
          allow="autoplay; fullscreen; picture-in-picture"
          allowfullscreen
          frameborder="0"></iframe>
      </div>
    <% end %>
  </header>

  <article class="article-body prose">
    <%= simple_format(@article.content) %>
  </article>

  <%# Optional: download button if you later use file_url %>
  <% if @article.file_url.present? %>
    <div class="article-download mt-4">
      <%= link_to "Télécharger la pièce jointe", @article.file_url, class: "btn btn-primary", download: true %>
    </div>
  <% end %>
</div>
