<div class="top-margin">


  <div class="articles-page">
    <h1 class="articles-title">Le numérique en Nouvelle-Aquitaine</h1>

    <div class="articles-grid">
      <% @articles.reverse.each do |article| %>
        <article class="article-card">
          <a class="article-media" href="<%= article_path(article) %>">
            <% if article.media.attached? %>
              <% cover = article.media.first %> <!-- get an attachment -->
              <% if cover.content_type.start_with?("image/") %>
                <%= image_tag cover, alt: article.title %>
              <% elsif cover.content_type.start_with?("video/") %>
                <%= video_tag url_for(cover), muted: true, playsinline: true, preload: "metadata" %>
                <span class="play-badge" aria-hidden="true">▶</span>
              <% end %>
            <% else %>
              <div class="media-placeholder"></div>
            <% end %>
          </a>

          <h2 class="article-card__title"><%= link_to article.title, article_path(article) %></h2>
          <p class="article-card__meta"><%= article.date&.strftime("%d %B %Y") %></p>
          <p class="article-card__excerpt"><%= truncate(strip_tags(article.content), length: 280) %></p>

          <div class="article-card__share">
            <span>Partager l’article</span>
            <i class="fa-brands fa-linkedin"></i>
            <i class="fa-brands fa-square-instagram"></i>
          </div>
        </article>
      <% end %>
    </div>
  </div>

</div>
