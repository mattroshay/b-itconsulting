<% set_meta_tags(
     title: "Blog IT | Le numérique en Nouvelle-Aquitaine",
     description: "Articles sur l'innovation numérique, la transformation digitale et les projets IT en Nouvelle-Aquitaine.",
     canonical: articles_url
   ) %>

<div class="top-margin">
  <div class="articles-page">
    <h1 class="articles-title">Le numérique en Nouvelle-Aquitaine</h1>

    <div class="articles-grid">
      <% @articles.reverse.each do |article| %>
        <article class="article-card">
          <%= link_to article_path(article), class: "article-media" do %>
            <% if article.images.attached? %>
              <%= image_tag url_for(article.images.first), alt: article.title %>
            <% elsif article.video_embed_url.present? %>
              <iframe
                src="<%= article.video_embed_url %>"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                frameborder="0">
              </iframe>
              <span class="play-badge" aria-hidden="true">▶</span>
            <% end %>
          <% end %>

          <h2 class="article-card__title blue">
            <%= link_to article.title, article_path(article) %>
          </h2>
          <p class="article-card__meta"><%= article.date&.strftime("%d %B %Y") %></p>
          <p class="article-card__excerpt"><%= truncate(strip_tags(article.content), length: 280) %></p>

          <div class="article-card__share">
            <span>Partager l’article</span>
            <i class="fa-brands fa-linkedin"></i>
            <i class="fa-brands fa-square-instagram"></i>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</div>
