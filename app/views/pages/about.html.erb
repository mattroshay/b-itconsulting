<div class="top-margin"></div>
<div class="flexbox3">
  <div></div>
  <div>
    <h1 class="text-center">À propos de moi : Expériences, Formations et Projets Futurs</h1>
    <h2 class="text-center">Expériences</h2>
    <p class="text-center">Découvrez ici un aperçu de mes expériences professionnelles, ma formation académique et mes ambitions pour l’avenir. Mon objectif est de mettre mes compétences au service de projets innovants et collaboratifs.</p>
  </div>
  <div></div>
</div>

<div class="experience-section">
  <div></div>

  <img
    src="<%= cl_image_path('Photo_cv_Pascal_Rousse_Large_mzx2aj', fetch_format: :auto) %>"
    alt="buildings"
    class="img-experience"
  />

  <div class="timeline-left">
    <% @experiences1_by_company.each_with_index do |(company, exps), idx| %>
      <details class="experience-card" <%= 'open' if idx.zero? %>>
        <summary class="experience-header">
          <p><strong><%= company %></strong></p>
          <%= simple_format(
                exps.first[:period],
                { class: 'no-bottom-margin' },
                sanitize: false
              ) %>
        </summary>

        <div class="experience-body">
          <% exps.each do |exp| %>
            <div class="role-block mb-3">
              <h4><%= exp[:role] %></h4>
              <%= simple_format(
                    exp[:details],
                    {},
                    sanitize: false
                  ) %>
            </div>
          <% end %>

          <%= link_to(
                'En savoir plus',
                exps.first[:url],
                class: 'border-radius button button-center',
                target: '_blank'
              ) %>
        </div>
      </details>
    <% end %>
  </div>

  <div></div>
</div>

