<% set_meta_tags(
     title: "À propos de Benoît Marfany | Parcours et expériences IT",
     description: "Découvrez les expériences, formations et projets futurs de Benoît Marfany, administrateur d'infrastructures sécurisées et chef de projet IT.",
     image: cl_image_path('Photo_cv_Pascal_Rousse_Large_mzx2aj', fetch_format: :auto),
     canonical: about_url
   ) %>

<div class="top-margin"></div>
<div class="flexbox3">
  <div></div>
  <div>
    <h1 class="text-center">À propos de moi : Expériences, Formations et Projets Futurs</h1>
    <h2 class="text-center">Expériences</h2>
    <p class="text-center">Découvrez ici un aperçu de mes expériences professionnelles, ma formation académique et mes ambitions pour l’avenir. Mon objectif est de mettre mes compétences au service de projets innovants et collaboratifs.</p>
  </div>
  <div></div>
</div>

<section class="experience the-line">
  <div class="experience-section">
    <div></div>

    <img
      src="<%= cl_image_path('Photo_cv_Pascal_Rousse_Large_mzx2aj', fetch_format: :auto) %>"
      alt="Portrait professionnel de Benoît Marfany"
      class="img-experience"
    />

    <div class="timeline-left">
      <% @experiences1_by_company.each_with_index do |(company, exps), idx| %>
        <details class="experience-card" <%= 'open' if idx.zero? %>>
          <summary class="experience-header">
            <p><strong><%= company %></strong></p>
            <%= simple_format(
                  exps.first[:period],
                  { class: 'no-bottom-margin' },
                  sanitize: false
                ) %>
          </summary>

          <div class="experience-body">
            <% exps.each do |exp| %>
              <div class="role-block mb-3">
                <%# <h4><%= exp[:role] %>
                <%= simple_format(
                      exp[:role],
                      {},
                      sanitize: false
                    ) %>
                <%= simple_format(
                      exp[:details],
                      {},
                      sanitize: false
                    ) %>
              </div>
            <% end %>

            <%= link_to(
                  'En savoir plus',
                  exps.first[:url],
                  class: 'border-radius button button-center',
                  target: '_blank'
                ) %>
          </div>
        </details>
      <% end %>
    </div>

    <div></div>
  </div>

  <div class="experience-section experience-section-2">
    <div></div>

    <div class="timeline-right">
      <% @experiences2_by_company.each_with_index do |(company, exps), idx| %>
        <details class="experience-card">
          <summary class="experience-header">
            <p><strong><%= company %></strong></p>
            <%= simple_format(
                  exps.first[:period],
                  { class: 'no-bottom-margin' },
                  sanitize: false
                ) %>
          </summary>

          <div class="experience-body">
            <% exps.each do |exp| %>
              <div class="role-block mb-3">
                <%= simple_format(
                      exp[:role],
                      {},
                      sanitize: false
                    ) %>
                <%= simple_format(
                      exp[:details],
                      {},
                      sanitize: false
                    ) %>
              </div>
            <% end %>

            <%= link_to(
                  'En savoir plus',
                  exps.first[:url],
                  class: 'border-radius button button-center',
                  target: '_blank'
                ) %>
          </div>
        </details>
      <% end %>
    </div>

    <img
      src="<%= cl_image_path('Image_expérience_2_1_c3leee', fetch_format: :auto) %>"
      alt="Illustration d'une collaboration IT en cours"
      class="img-experience img-experience-2"
    />

    <div></div>
  </div>

  <div class="experience-section end-of-line">
    <div></div>

    <img
      src="<%= cl_image_path('Image_expérience_3_1_hw6rtk', fetch_format: :auto) %>"
      alt="Illustration d'une équipe projet en stratégie numérique"
      class="img-experience end-of-section"
    />

    <div class="timeline-left">
      <% @experiences3_by_company.each_with_index do |(company, exps), idx| %>
        <details class="experience-card">
          <summary class="experience-header">
            <p><strong><%= company %></strong></p>
            <%= simple_format(
                  exps.first[:period],
                  { class: 'no-bottom-margin' },
                  sanitize: false
                ) %>
          </summary>

          <div class="experience-body">
            <% exps.each do |exp| %>
              <div class="role-block mb-3">
                <%= simple_format(
                      exp[:role],
                      {},
                      sanitize: false
                    ) %>
                <%= simple_format(
                      exp[:details],
                      {},
                      sanitize: false
                    ) %>
              </div>
            <% end %>

            <%= link_to(
                  'En savoir plus',
                  exps.first[:url],
                  class: 'border-radius button button-center',
                  target: '_blank'
                ) %>
          </div>
        </details>
      <% end %>
    </div>

    <div></div>
  </div>
</section>

<section class="formations" id="Formations">
  <div></div>
    <div class="formations-cards">
      <h2>Formations</h2>
      <% @formations.each_with_index do |formation, idx| %>
        <details class="formation-card" <%= 'open' if idx.zero? %>>
          <summary class="formation-header">
            <div class="formation-header-row">
              <p><strong><%= formation[:title] %></strong> <%= formation[:period] %></p>
              <p><%= formation[:institution] %></p>
            </div>
          </summary>

          <div class="formation-body">
              <div class="role-block mb-3">
                <h4><%= formation[:certification] %></h4>
                <%= simple_format(
                      formation[:details],
                      {},
                      sanitize: false
                    ) %>
              </div>

            <%= link_to(
                  'En savoir plus',
                  formation[:url],
                  class: 'border-radius button button-center',
                  target: '_blank'
                ) %>
          </div>
        </details>
      <% end %>
    </div>
  <div class="formation-image-wrapper">
    <img
      src="<%= cl_image_path('Formations_mu5g06', fetch_format: :auto) %>"
      alt="Illustration symbolisant les parcours de formation IT"
      class="img-formation end-of-section"
    />
  </div>
  <div></div>
</section>

<section class="projets-futurs background-image " id="projets-futurs" style="background-image: url('<%= cl_image_path("projet_futur_Large_ro37jn", fetch_format: :auto) %>');">
  <div></div>
  <div class="formations-cards">
    <h2 class="white">Projets Futurs</h2>
    <% @projets_futurs.each_with_index do |projets, idx| %>
      <details class="formation-card"<%= 'open' if idx.zero? %>>
        <summary class="formation-header">
          <div class="formation-header-row">
            <p><strong><%= projets[:title] %></strong></p>
          </div>
        </summary>

        <div class="formation-body">
            <div class="role-block mb-3 custom-list">
              <h4><%= projets[:sub_title] %></h4>
              <%= simple_format(
                    projets[:details],
                    {},
                    sanitize: false
                  ) %>
            </div>

          <%= link_to(
                'En savoir plus',
                projets[:url],
                class: 'border-radius button button-center',
                target: '_blank'
              ) %>
        </div>
      </details>
    <% end %>
  </div>
</section>
