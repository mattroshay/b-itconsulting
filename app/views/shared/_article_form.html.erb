
<%= form_with model: article, local: true do |f| %>
  <%= f.label :title %>
  <%= f.text_field :title %>

  <%= f.label :date %>
  <%= f.date_field :date %>

  <%= f.label :content %>
  <%= f.text_area :content, rows: 10 %>

  <%= f.label :media, "Photos/Vidéos (sélection multiple)" %>
  <%= f.file_field :media, multiple: true, accept: "image/*,video/*" %>

  <%= f.submit %>
<% end %>
